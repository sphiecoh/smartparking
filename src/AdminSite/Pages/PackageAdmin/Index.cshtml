@page
@model AdminSite.Pages.Packages.IndexModel
@{
    ViewData["Title"] = "Packages";
    ViewData["Subtitle"] = "Subscription tiers available to tenants";
}

@section TopbarActions {
    <a href="/Packages/Create" class="btn btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Package
    </a>
}

<div class="card">
    <div class="card-header">
        <div class="search-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input class="search-input" data-search="[data-row='package']" placeholder="Search packages…" />
        </div>
        <span style="font-family:var(--mono);font-size:12px;color:var(--text-3)">@Model.Packages.Count total</span>
    </div>

    <div class="table-wrap">
        @if (!Model.Packages.Any())
        {
            <div class="empty-state">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                <h3>No packages yet</h3>
                <p>Create your first subscription package to get started.</p>
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Tenants</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Packages)
                    {
                        <tr data-row="package">
                            <td class="td-mono">@p.Id</td>
                            <td><strong>@p.Name</strong></td>
                            <td>
                                <span style="font-family:var(--mono);font-size:13px;color:var(--text-2)">
                                    @p.TenantCount tenant@(p.TenantCount != 1 ? "s" : "")
                                </span>
                            </td>
                            <td class="td-mono">@p.CreatedAt?.ToString("dd MMM yyyy")</td>
                            <td>
                                <div class="td-actions">
                                    <a href="/Packages/Edit?id=@p.Id" class="btn btn-icon edit" title="Edit">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </a>
                                    <button class="btn btn-icon delete" title="Delete"
                                            onclick="confirmDelete('/Packages/Delete?id=@p.Id', 'Delete package &quot;@p.Name&quot;? @(p.TenantCount > 0 ? "Warning: " + p.TenantCount + " tenant(s) use this package." : "This cannot be undone.")')">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@await Html.PartialAsync("_DeleteModal")
