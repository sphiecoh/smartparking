@page
@model AdminSite.Pages.Tenants.IndexModel
@{
    ViewData["Title"] = "Tenants";
    ViewData["Subtitle"] = "All registered organisations on the platform";
}

@section TopbarActions {
    <a href="/Tenants/Create" class="btn btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Tenant
    </a>
}

<div class="card">
    <div class="card-header">
        <div class="search-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input class="search-input" data-search="[data-row='tenant']" placeholder="Search tenants…" />
        </div>
        <div style="display:flex;gap:8px;align-items:center">
            <span style="font-family:var(--mono);font-size:12px;color:var(--text-3)">
                @Model.Tenants.Count(t => t.Active) active / @Model.Tenants.Count total
            </span>
        </div>
    </div>

    <div class="table-wrap">
        @if (!Model.Tenants.Any())
        {
            <div class="empty-state">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <h3>No tenants yet</h3>
                <p>Onboard your first organisation.</p>
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>URL</th>
                        <th>Package</th>
                        <th>Users</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Tenants)
                    {
                        <tr data-row="tenant">
                            <td class="td-mono">@t.Id</td>
                            <td><strong>@t.Name</strong></td>
                            <td class="td-mono" style="font-size:12px;color:var(--text-3)">@(t.Url ?? "—")</td>
                            <td>
                                @if (t.PackageName != null)
                                {
                                    <span style="font-size:13px;color:var(--text-2)">@t.PackageName</span>
                                }
                                else
                                {
                                    <span style="font-size:12px;color:var(--text-3)">None</span>
                                }
                            </td>
                            <td class="td-mono">@t.UserCount</td>
                            <td>
                                @if (t.Active)
                                {
                                    <span class="badge badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-inactive">Inactive</span>
                                }
                            </td>
                            <td class="td-mono">@t.CreatedAt?.ToString("dd MMM yyyy")</td>
                            <td>
                                <div class="td-actions">
                                    <a href="/TenantUsers?tenantId=@t.Id" class="btn btn-icon users" title="Manage users">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                    </a>
                                    <a href="/Tenants/Edit?id=@t.Id" class="btn btn-icon edit" title="Edit tenant">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </a>
                                    <button class="btn btn-icon delete" title="Delete tenant"
                                            onclick="confirmDelete('/Tenants/Delete?id=@t.Id', 'Delete tenant &quot;@t.Name&quot;? All associated data will be affected.')">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@await Html.PartialAsync("_DeleteModal")
