@page
@model AdminSite.Pages.Tenants.CreateModel
@{
    ViewData["Title"] = "New Tenant";
}

<div class="breadcrumb">
    <a href="/Tenants">Tenants</a>
    <span class="breadcrumb-sep">›</span>
    <span class="breadcrumb-current">New Tenant</span>
</div>

<div class="form-card">
    <form method="post">
        <div class="form-grid">
            <div class="field full">
                <label asp-for="Input.Name">Organisation Name</label>
                <input asp-for="Input.Name" placeholder="Acme Corporation" autofocus />
                <span asp-validation-for="Input.Name" class="field-validation-error"></span>
            </div>

            <div class="field full">
                <label asp-for="Input.Url">Portal URL</label>
                <input asp-for="Input.Url" placeholder="https://acme.yourdomain.com" type="url" />
                <span asp-validation-for="Input.Url" class="field-validation-error"></span>
                <span class="field-hint">Optional — used if tenant has a custom subdomain</span>
            </div>

            <div class="field">
                <label asp-for="Input.PackageId">Subscription Package</label>
                <select asp-for="Input.PackageId" asp-items="Model.Packages"></select>
            </div>

            <div class="field" style="justify-content:flex-end;padding-bottom:4px">
                <label>Status</label>
                <div class="toggle-wrap">
                    <input asp-for="Input.Active" type="checkbox" class="toggle" id="activeToggle" />
                    <label class="toggle-label" for="activeToggle">Active</label>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create Tenant</button>
            <a href="/Tenants" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>
