@page
@model AdminSite.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Platform overview";
}

<div class="stats-grid">
    <div class="stat-card blue">
        <div class="stat-label">Packages</div>
        <div class="stat-value blue">@Model.PackageCount</div>
        <div class="stat-meta">Subscription tiers defined</div>
    </div>
    <div class="stat-card green">
        <div class="stat-label">Active Tenants</div>
        <div class="stat-value green">@Model.ActiveTenantCount</div>
        <div class="stat-meta">of @Model.TotalTenantCount total</div>
    </div>
    <div class="stat-card amber">
        <div class="stat-label">Admin Users</div>
        <div class="stat-value amber">@Model.AdminUserCount</div>
        <div class="stat-meta">Across all tenants</div>
    </div>
</div>

<div class="recent-grid">
    <!-- Recent Tenants -->
    <div class="card">
        <div class="card-header">
            <h2>Recent Tenants</h2>
            <a href="/Tenants" class="btn btn-ghost btn-sm">View all</a>
        </div>
        <div style="padding: 0 20px;">
            @if (!Model.RecentTenants.Any())
            {
                <div class="empty-state" style="padding:30px 0;">
                    <p>No tenants yet.</p>
                </div>
            }
            else
            {
                @foreach (var t in Model.RecentTenants)
                {
                    <div class="activity-item">
                        <div class="activity-dot" style="background: @(t.Active ? "var(--success)" : "var(--text-3)")"></div>
                        <div class="activity-text">
                            <strong>@t.Name</strong>
                            <div style="font-size:12px;color:var(--text-3);font-family:var(--mono)">@(t.Package ?? "No package")</div>
                        </div>
                        <span class="activity-time">@t.CreatedAt?.ToString("dd MMM")</span>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Recent Users -->
    <div class="card">
        <div class="card-header">
            <h2>Recent Admin Users</h2>
            <a href="/TenantUsers" class="btn btn-ghost btn-sm">View all</a>
        </div>
        <div style="padding: 0 20px;">
            @if (!Model.RecentUsers.Any())
            {
                <div class="empty-state" style="padding:30px 0;">
                    <p>No admin users yet.</p>
                </div>
            }
            else
            {
                @foreach (var u in Model.RecentUsers)
                {
                    <div class="activity-item">
                        <div class="activity-dot" style="background:var(--accent)"></div>
                        <div class="activity-text">
                            <strong>@u.Name</strong>
                            <div style="font-size:12px;color:var(--text-3);font-family:var(--mono)">@u.Tenant · @u.Email</div>
                        </div>
                        <span class="activity-time">@u.CreatedAt?.ToString("dd MMM")</span>
                    </div>
                }
            }
        </div>
    </div>
</div>
