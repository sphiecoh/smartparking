@page
@model AdminSite.Pages.TenantUsers.IndexModel
@{
    ViewData["Title"] = Model.FilterTenant != null ? $"{Model.FilterTenant} — Admin Users" : "Admin Users";
    ViewData["Subtitle"] = "Tenant administrator accounts";
}

@section TopbarActions {
    <a href="/TenantUsers/Create@(Model.FilterTenantId.HasValue ? "?tenantId=" + Model.FilterTenantId : "")" class="btn btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Admin User
    </a>
}

@if (Model.FilterTenant != null)
{
    <div class="breadcrumb">
        <a href="/Tenants">Tenants</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">@Model.FilterTenant — Users</span>
    </div>
}

<div class="card">
    <div class="card-header">
        <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap">
            <div class="search-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input class="search-input" data-search="[data-row='user']" placeholder="Search users…" />
            </div>
            @if (Model.FilterTenantId == null)
            {
                <form method="get" style="display:flex;gap:8px;align-items:center">
                    <select name="tenantId" onchange="this.form.submit()"
                            style="background:var(--bg-3);border:1px solid var(--border);border-radius:var(--radius);padding:8px 12px;color:var(--text);font-family:var(--sans);font-size:13px;outline:none">
                        <option value="">All tenants</option>
                        @foreach (var t in Model.AllTenants)
                        {
                            <option value="@t.Id" selected="@(Model.FilterTenantId == t.Id)">@t.Name</option>
                        }
                    </select>
                </form>
            }
        </div>
        <span style="font-family:var(--mono);font-size:12px;color:var(--text-3)">@Model.Users.Count user@(Model.Users.Count != 1 ? "s" : "")</span>
    </div>

    <div class="table-wrap">
        @if (!Model.Users.Any())
        {
            <div class="empty-state" data-empty>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                <h3>No admin users</h3>
                <p>@(Model.FilterTenant != null ? $"No users for {Model.FilterTenant} yet." : "Create an admin user to get started.")</p>
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Tenant</th>
                        <th>Role</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Users)
                    {
                        <tr data-row="user">
                            <td class="td-mono">@u.Id</td>
                            <td><strong>@(u.FullName ?? u.Username)</strong></td>
                            <td class="td-mono">@u.Username</td>
                            <td style="font-size:13px;color:var(--text-2)">@(u.Email ?? "—")</td>
                            <td>
                                <a href="/TenantUsers?tenantId=@u.TenantId"
                                   style="color:var(--accent);text-decoration:none;font-size:13px">
                                    @u.TenantName
                                </a>
                            </td>
                            <td>
                                @if (u.RoleName != null)
                                {
                                    <span class="badge badge-admin">@u.RoleName</span>
                                }
                                else
                                {
                                    <span style="color:var(--text-3);font-size:12px">—</span>
                                }
                            </td>
                            <td class="td-mono">@u.CreatedAt?.ToString("dd MMM yyyy")</td>
                            <td>
                                <div class="td-actions">
                                    <a href="/TenantUsers/Edit?id=@u.Id" class="btn btn-icon edit" title="Edit">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </a>
                                    <button class="btn btn-icon delete" title="Delete"
                                            onclick="confirmDelete('/TenantUsers/Delete?id=@u.Id', 'Delete admin user &quot;@(u.FullName ?? u.Username)&quot;? They will lose access immediately.')">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@await Html.PartialAsync("_DeleteModal")
