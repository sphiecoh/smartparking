@page
@model AdminSite.Pages.TenantUsers.EditModel
@{
    ViewData["Title"] = "Edit Admin User";
}

<div class="breadcrumb">
    <a href="/TenantUsers">Admin Users</a>
    <span class="breadcrumb-sep">›</span>
    <span class="breadcrumb-current">Edit</span>
</div>

<div class="form-card">
    <form method="post" asp-route-id="@Model.UserId">
        <div class="form-grid">

            <div class="field">
                <label asp-for="Input.FullName">Full Name</label>
                <input asp-for="Input.FullName" autofocus />
                <span asp-validation-for="Input.FullName" class="field-validation-error"></span>
            </div>

            <div class="field">
                <label asp-for="Input.Username">Username</label>
                <input asp-for="Input.Username" autocomplete="off" />
                <span asp-validation-for="Input.Username" class="field-validation-error"></span>
            </div>

            <div class="field full">
                <label asp-for="Input.Email">Email Address</label>
                <input asp-for="Input.Email" type="email" />
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </div>

            <div class="field">
                <label asp-for="Input.TenantId">Tenant</label>
                <select asp-for="Input.TenantId" asp-items="Model.Tenants"></select>
                <span asp-validation-for="Input.TenantId" class="field-validation-error"></span>
            </div>

            <div class="field">
                <label asp-for="Input.RoleId">Role</label>
                <select asp-for="Input.RoleId" asp-items="Model.Roles"></select>
            </div>

            <div class="field full" style="border-top:1px solid var(--border);padding-top:20px;margin-top:4px">
                <label style="color:var(--text-3)">Change Password <span style="font-weight:400;text-transform:none;letter-spacing:0">(leave blank to keep current)</span></label>
            </div>

            <div class="field">
                <label asp-for="Input.NewPassword">New Password</label>
                <input asp-for="Input.NewPassword" type="password" autocomplete="new-password"
                       data-pw-strength="#pwBar" placeholder="Min 8 characters" />
                <div class="pw-strength"><div class="pw-strength-bar" id="pwBar"></div></div>
                <span asp-validation-for="Input.NewPassword" class="field-validation-error"></span>
            </div>

            <div class="field">
                <label asp-for="Input.ConfirmPassword">Confirm New Password</label>
                <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
            </div>

        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/TenantUsers" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>
