<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Control Panel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<div class="shell">

    <!-- ── Sidebar ──────────────────────────────────── -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <span class="brand-icon">⬡</span>
            <span class="brand-name">Control<br><strong>Panel</strong></span>
        </div>

        <nav class="sidebar-nav">
            <span class="nav-section-label">Platform</span>

            <a href="/" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                Dashboard
            </a>

            <span class="nav-section-label" style="margin-top:1.5rem">Configuration</span>

            <a href="/PackageAdmin" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/PackageAdmin") == true ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                Packages
            </a>

            <a href="/Tenants" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Tenants") == true ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Tenants
            </a>

            <a href="/TenantUsers" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/TenantUsers") == true ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Admin Users
            </a>
        </nav>

        <div class="sidebar-footer">
            <form method="post" action="/Logout">
                <button type="submit" class="signout-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    Sign out
                </button>
            </form>
        </div>
    </aside>

    <!-- ── Main ─────────────────────────────────────── -->
    <main class="main">
        <header class="topbar">
            <div class="topbar-title">
                <h1>@ViewData["Title"]</h1>
                @if (ViewData["Subtitle"] != null)
                {
                    <p class="topbar-subtitle">@ViewData["Subtitle"]</p>
                }
            </div>
            <div class="topbar-actions">
                @await RenderSectionAsync("TopbarActions", required: false)
            </div>
        </header>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                @TempData["Error"]
            </div>
        }

        <div class="content">
            @RenderBody()
        </div>
    </main>
</div>

<script src="~/js/admin.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
